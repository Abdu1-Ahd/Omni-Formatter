    "configuration": {
      "title": "OmniFormatter",
      "properties": {
        "omniFormatter.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable OmniFormatter for all supported languages."
        },
        "omniFormatter.registryUrl": {
          "type": "string",
          "default": "https://Abdu1-Ahd.github.io/Omni-Formatter",
          "description": "Base URL of the OmniFormatter WASM registry. Used to download language modules.",
          "format": "uri"
        },
        "omniFormatter.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug"
          ],
          "default": "warn",
          "description": "Log verbosity level for the OmniFormatter output channel."
        },
        "omniFormatter.ignoreAutoSave": {
          "type": "boolean",
          "default": true,
          "description": "Ignore VS Code's native format-on-save when triggered by auto-save (e.g., onFocusChange). Only format on manual save (Ctrl+S/Cmd+S) or explicit format commands."
        }
      }
    },
