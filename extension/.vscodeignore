.vscode/**
.vscode-test/**
src/**
.gitignore
.eslintrc.json
tsconfig.json
**/*.map
**/*.ts

# The out/ directory is a duplicate of dist/src/ — not needed at runtime
out/**

# WAT is the human-readable TEXT version of the WASM binary, never loaded at runtime
dist/wasm/*.wat
dist/wasm/out.txt

# Python dev-tooling scripts bundled by accident
dist/wasm/*.py

# Lock files have no value inside a packaged extension
pnpm-lock.yaml
package-lock.json

# Stray .gitignore files inside dist/
dist/**/.gitignore

# Only media/logo.png is referenced by package.json — extras not needed
media/logos/**

# Exclude source code directories from extension build
/workers/**
/src/**
/tests/**

# Exclude all dependencies (esbuild bundles everything we need)
node_modules/**

# Exclude development/agent directories and files
.gemini/**
.github/**
.code-review-graph/**
.kiro/**
FLAWS.md
EXTENSION_CONTEXT.md
.antigravityrules
wasi-sdk/**
wasi-sdk.tar.gz
temp/**
registry/**
publish-extension.exe
scripts/**

# VERY IMPORTANT: Un-ignore the compiled output at the very end 
# to override any broad ignore rules above
!dist/**/*.js
!dist/**/*.wasm
