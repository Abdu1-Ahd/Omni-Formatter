{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OmniFormatter Java/Kotlin Config",
  "type": "object",
  "properties": {
    "indent_size": { "type": "integer", "default": 4 },
    "column_limit": { "type": "integer", "default": 100 },
    "brace_style":  { "type": "string", "enum": ["Attach", "Allman"], "default": "Attach" }
  }
}
