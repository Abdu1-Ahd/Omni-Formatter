{
  "$schema": "https://raw.githubusercontent.com/Abdu1-Ahd/Omni-Formatter/main/docs/omnifmt.schema.json",
  "version": 1,

  "_comment": "This is the OmniFormatter configuration file. It is optional — OmniFormatter works zero-config by reading your existing native config files (.prettierrc, pyproject.toml, rustfmt.toml, etc.). Use this file ONLY when you need to override native configs or set cross-language options.",

  "javascript": {
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "singleQuote": false,
    "semi": true,
    "trailingComma": "all",
    "endOfLine": "lf"
  },

  "typescript": {
    "$ref": "#/javascript"
  },

  "python": {
    "lineLength": 88,
    "skipStringNormalization": false,
    "targetVersion": ["py311"]
  },

  "rust": {
    "maxWidth": 100,
    "tabSpaces": 4,
    "edition": "2021"
  },

  "go": {
    "organizeImports": true
  },

  "css": {
    "printWidth": 80,
    "singleQuote": false
  },

  "html": {
    "printWidth": 80,
    "htmlWhitespaceSensitivity": "css"
  },

  "global": {
    "postFormat": []
  }
}
